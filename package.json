{
    "name": "@supercat1337/ui",
    "version": "2.0.0",
    "description": "UI library for building high-performance web interfaces with native JavaScript",
    "license": "MIT",
    "author": "Albert Bazaleev",
    "type": "module",
    "main": "dist/ui.esm.js",
    "homepage": "https://github.com/supercat1337/ui",
    "repository": {
        "url": "git+https://github.com/supercat1337/ui.git"
    },
    "keywords": [
        "ui-library",
        "vanilla-js",
        "components",
        "ssr",
        "hydration",
        "dom-scope",
        "high-performance",
        "lightweight",
        "no-vdom",
        "isomorphic",
        "typescript",
        "event-emitter",
        "esm"
    ],
    "exports": {
        ".": {
            "import": {
                "types": "./dist/ui.esm.d.ts",
                "default": "./dist/ui.esm.js"
            },
            "browser": {
                "types": "./dist/ui.bundle.esm.d.ts",
                "default": "./dist/ui.bundle.esm.js"
            }
        }
    },
    "scripts": {
        "build": "npm run clean && npm run build_esm && npm run build_bundle_esm && npm run build_bundle_esm_min && npm run create_types",
        "clean": "shx rm -rf ./dist && shx mkdir ./dist",
        "build_esm": "rollup ./src/index.js --file ./dist/ui.esm.js --format es",
        "build_bundle_esm": "esbuild --bundle --platform=neutral --legal-comments=none ./src/index.js --outfile=./dist/ui.bundle.esm.js",
        "build_bundle_esm_min": "esbuild --minify --bundle --platform=neutral --legal-comments=none ./src/index.js --outfile=./dist/ui.bundle.esm.min.js",
        "create_types": "tsc --project my.tsconfig.types.json && shx cp ./dist/ui.esm.d.ts ./dist/ui.bundle.esm.d.ts",
        "examples": "live-server --open=./examples --watch=dist,examples"
    },
    "dependencies": {
        "@supercat1337/event-emitter": "^2.0.0",
        "dom-scope": "^2.1.2"
    },
    "devDependencies": {
        "jsdom": "^28.1.0",
        "live-server": "^1.2.0",
        "shx": "^0.4.0"
    }
}
